{
  "__comment": "Step 15: Grafana dashboard for Investment Advisory AI Agent. Import via Grafana UI → Dashboards → Import.",
  "title": "Investment Advisory AI Agent",
  "uid": "invest-advisory-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Recommendations",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(investment_recommendations_total)",
          "legendFormat": "Recommendations"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Recommendation Latency (p95)",
      "gridPos": { "x": 6, "y": 0, "w": 10, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(investment_recommendation_latency_ms_bucket[1m]))",
          "legendFormat": "p95 latency (ms)"
        }
      ]
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Recommendations by Risk Profile",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum by (risk) (investment_recommendations_total)",
          "legendFormat": "{{risk}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "Recommendations by Goal Horizon",
      "gridPos": { "x": 8, "y": 4, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum by (goal) (investment_recommendations_total)",
          "legendFormat": "{{goal}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Claude Input Tokens (cumulative)",
      "gridPos": { "x": 0, "y": 10, "w": 5, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "sum(claude_input_tokens_total)",
          "legendFormat": "Input Tokens"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Claude Output Tokens (cumulative)",
      "gridPos": { "x": 5, "y": 10, "w": 5, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "sum(claude_output_tokens_total)",
          "legendFormat": "Output Tokens"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Claude API Cost (cumulative USD)",
      "gridPos": { "x": 10, "y": 10, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(claude_cost_usd_total)",
          "legendFormat": "Cost (USD)"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Claude Token Usage Over Time",
      "gridPos": { "x": 0, "y": 14, "w": 16, "h": 5 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "claude_input_tokens_total",
          "legendFormat": "Input Tokens — {{model}}"
        },
        {
          "expr": "claude_output_tokens_total",
          "legendFormat": "Output Tokens — {{model}}"
        }
      ]
    }
  ],
  "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  }
}
