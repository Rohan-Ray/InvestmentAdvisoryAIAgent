{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p $HOME/InvestmentAdvisoryAIAgent/observability && echo '[HOOK] PreToolUse:Bash - $(date +%Y-%m-%dT%H:%M:%S)' >> $HOME/InvestmentAdvisoryAIAgent/observability/hooks.log"
          },
          {
            "type": "command",
            "command": "python3 $HOME/InvestmentAdvisoryAIAgent/.claude/hooks/guardrail-bash.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/InvestmentAdvisoryAIAgent/.claude/hooks/guardrail-write.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p $HOME/InvestmentAdvisoryAIAgent/observability && echo '[HOOK] PostToolUse:FileWrite - $(date +%Y-%m-%dT%H:%M:%S)' >> $HOME/InvestmentAdvisoryAIAgent/observability/hooks.log"
          },
          {
            "type": "command",
            "command": "python3 $HOME/InvestmentAdvisoryAIAgent/.claude/hooks/guardrail-secrets.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p $HOME/InvestmentAdvisoryAIAgent/observability && echo '[HOOK] AgentStop - $(date +%Y-%m-%dT%H:%M:%S)' >> $HOME/InvestmentAdvisoryAIAgent/observability/hooks.log"
          }
        ]
      }
    ]
  },
  "env": {
    "INVESTMENT_APP_ENV": "development",
    "OTEL_SERVICE_NAME": "investment-advisory-agent",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "LOG_LEVEL": "INFO",
    "RAG_CHUNK_SIZE": "512",
    "RAG_OVERLAP": "64",
    "MCP_SERVER_PORT": "8765"
  }
}
